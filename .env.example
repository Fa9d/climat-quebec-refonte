# =============================================================================
# Variables d'environnement — Climat Québec
# Copiez ce fichier en .env.local et renseignez vos valeurs Supabase.
# Ne jamais committer .env.local dans le dépôt.
# =============================================================================

# Supabase — obtenez ces valeurs dans Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# (optionnel) Clé service-role : ne jamais exposer côté client
# SUPABASE_SERVICE_ROLE_KEY=...
